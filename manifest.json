{
  "manifest_version": 3,
  "name": "Summarize & Recall",
  "version": "0.1",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "./background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["./content/content.js"],
      "type": "module",
      "run_at": "document_idle"
    }
  ]
}
